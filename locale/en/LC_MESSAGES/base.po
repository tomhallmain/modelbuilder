msgid ""
"Target number of images to gather (default: from pipeline "
"data.gather.default_target_count). Treated as a limit, not an exact "
"requirement."
msgstr ""
"Target number of images to gather (default: from pipeline "
"data.gather.default_target_count). Treated as a limit, not an exact "
"requirement."

