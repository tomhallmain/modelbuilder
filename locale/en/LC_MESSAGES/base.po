msgid "Output data directory (default: data)"
msgstr "Output data directory (default: data)"

#: mb/cli.py:280
msgid ""
"Number of items per class in the test split (default: 1000). For image "
"classification this is test images per class."
msgstr ""
"Number of items per class in the test split (default: 1000). For image "
"classification this is test images per class."

