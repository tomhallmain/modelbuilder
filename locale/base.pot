msgid "Scan and print duplicate groups as indented JSON (no removals). Useful for manual review workflows."
msgstr ""

#: mb/cli/parsing/data.py:176
msgid ""
"Optional unified snapshot run ID to update with deduplication metadata. If omitted, the latest loadable snapshot "
"under raw data is used when available."
msgstr ""

#: mb/cli/parsing/data.py:184
msgid "Upscale small images"
msgstr ""

#: mb/cli/parsing/data.py:186
msgid ""
"Upscale images that are smaller than a minimum dimension threshold. Small images are moved to a review directory for "
"manual inspection before upscaling."
msgstr ""

