#: mb/cli.py:50
msgid "Model Builder - A unified CLI for building ML models"
msgstr ""
"Modellbauer - Eine einheitliche Befehlszeilenschnittstelle zum Erstellen von"
" ML-Modellen"

#: mb/cli.py:65
msgid "Path to configuration file (YAML)"
msgstr "Pfad zur Konfigurationsdatei (YAML)"

#: mb/cli.py:71
msgid "Enable verbose logging"
msgstr "Ausführliche Protokollierung aktivieren"

#: mb/cli.py:77
msgid "Available commands"
msgstr "Verfügbare Befehle"

#: mb/cli.py:84
msgid "Data processing operations"
msgstr "Datenverarbeitungsvorgänge"

#: mb/cli.py:85
msgid "Data processing operations for preparing image datasets"
msgstr "Datenverarbeitungsaufgaben zur Vorbereitung von Bild-Datensätzen"

#: mb/cli.py:89
msgid "Data subcommands"
msgstr "Datenunterbefehle"

#: mb/cli.py:96
msgid "Gather images from source directories"
msgstr "Bilder aus den Quellenordnern sammeln"

#: mb/cli.py:98
msgid ""
"Gather images from source directories into a target directory, with "
"deduplication and optional weighting by subdirectory."
msgstr ""
"Bilder aus Quellverzeichnissen in ein Zielverzeichnis zusammenführen, mit "
"Duplikatsbereinigung und optionaler Gewichtung nach Unterverzeichnissen."

#: mb/cli.py:106
msgid "Source directory containing images"
msgstr "Quelldirectory enthält Images"

#: mb/cli.py:112
msgid "Subdirectories to process"
msgstr "Unterverzeichnisse zu verarbeiten"

#: mb/cli.py:107
msgid "Target number of images to gather (default: 16000)"
msgstr "Angestrebte Anzahl der zu erfassenden Bilder (Standard: 16000)"

#: mb/cli.py:113
msgid "Target directory for gathered images (default: raw_data/coherent)"
msgstr "Zielverzeichnis für gesammelte Bilder (Standard: raw_data/kohärent)"

#: mb/cli.py:118
msgid "Rejected directory for manually rejected images"
msgstr "Abgelehntes Verzeichnis für manuell abgelehnte Bilder"

#: mb/cli.py:123
msgid ""
"Relative weights for subdirectories in format "
"\"subdir1:weight1,subdir2:weight2\""
msgstr ""
"Relative Gewichte für Unterordner im Format "
"'subdir1:gewicht1,subdir2:gewicht2'"

#: mb/cli.py:129
msgid "Root directory for raw data (default: raw_data)"
msgstr "Stammverzeichnis für rohe Daten (Standardwert: raw_data)"

#: mb/cli.py:163
msgid "Convert images to specified format"
msgstr "Bilder in das/zum angegebenen Format konvertieren"

#: mb/cli.py:165
msgid ""
"Convert images in the raw data directory to a specified format (e.g., JPEG)."
" Large images are automatically resized to prevent memory issues."
msgstr ""
"Konvertieren Sie Bilder im Rohdatenverzeichnis in den gewünschten Format "
"(z.B. JPEG). Große Bilder werden automatisch resize um Speicherprobleme zu "
"verhindern."

#: mb/cli.py:173 mb/cli.py:226 mb/cli.py:252
msgid "Raw data directory (default: raw_data)"
msgstr "Rohdatenverzeichnis (Standard: raw_data)"

#: mb/cli.py:151
msgid "Target format (default: jpeg)"
msgstr "Zielformat (Standard: jpeg)"

#: mb/cli.py:197
msgid "Remove duplicate images"
msgstr "Doppelbilder entfernen"

#: mb/cli.py:199
msgid ""
"Remove duplicate images within and across class directories. Uses perceptual"
" hashing to identify duplicates and moves them to a review directory."
msgstr ""
"Entfernt doppelte Bilder innerhalb und zwischen den Klassenverzeichnissen. "
"Nutzt Perceptual Hashing, um Duplikate zu identifizieren, und verschiebt "
"diese in ein Überprüfungsverzeichnis."

#: mb/cli.py:216
msgid "Upscale small images"
msgstr "Kleine Bilder hochskalieren"

#: mb/cli.py:218
msgid ""
"Upscale images that are smaller than a minimum dimension threshold. Small "
"images are moved to a review directory for manual inspection before "
"upscaling."
msgstr ""
"Bilder, die kleiner als ein festgelegter Mindestwert sind, werden "
"vergrößert. Kleine Bilder werden vor der Vergrößerung zur manuellen "
"Überprüfung in ein Überprüfungsverzeichnis verschoben."

#: mb/cli.py:188
msgid ""
"Review directory containing small images (default: "
"raw_data/small_images_review)"
msgstr ""
"Übersichtsverzeichnis enthält kleine Bilder (Standard: "
"raw_data/small_images_review)"

#: mb/cli.py:241
msgid "Create train/test dataset splits"
msgstr "Erstelle Training-/Test-Datensatz-Zerteilungen"

#: mb/cli.py:243
msgid ""
"Create training and test dataset splits from raw data. Validates images, "
"removes corrupted files, filters by size, and creates balanced train/test "
"splits with hash-based filenames."
msgstr ""
"Create training and test dataset splits from raw data. Validates images, "
"removes corrupted files, filters by size, and creates balanced train/test "
"splits with hash-based filenames."

#: mb/cli.py:258
msgid "Output data directory (default: data)"
msgstr "Ausgabeverzeichnis (Standard: data)"

#: mb/cli.py:217
msgid "Number of test images per class (default: 1000)"
msgstr "Anzahl der Testbilder pro Klassen (voreinstellung: 1000)"

#: mb/cli.py:272
msgid "Random seed for reproducibility"
msgstr "Zufallsschub für die Wiederherstellbarkeit"

#: mb/cli.py:277 mb/cli.py:381
msgid ""
"Run ID of unified snapshot to update (auto-detects latest if not provided)"
msgstr ""
"Run-ID von einem einheitlichen Snapshot zum Anzupdaten (Automatisch den "
"neuesten ermitteln, wenn keiner angegeben ist)."

#: mb/cli.py:232
msgid "Balance training set to smallest class size"
msgstr "Ausgleichen des Trainingsdatensatzes auf die kleinste Klassengröße"

#: mb/cli.py:237
msgid "Maximum number of training images per class"
msgstr "Maximale Anzahl von trainingsbildern pro Klasse"

#: mb/cli.py:296
msgid "Allow running on external/removable storage (not recommended)"
msgstr ""
"Ermöglichen das Laufenlassen auf externen/entfernungsschreibbaren "
"Speichermedien (nicht empfohlen)"

#: mb/cli.py:302
msgid "Train a model"
msgstr "Trainieren Sie ein Modell"

#: mb/cli.py:304
msgid ""
"Train a machine learning model using the specified framework and "
"architecture. Supports transfer learning with frozen/unfrozen training "
"phases."
msgstr ""
"Trainieren Sie ein Modell für maschinelles Lernen unter Verwendung des "
"angegebenen Frameworks und der angegebenen Architektur. Unterstützt "
"Transferlernen mit „gefrorenen“ und „nicht gefrorenen“ Trainingsphasen."

#: mb/cli.py:312
msgid "Model type (default: image_classification)"
msgstr "Modelltyp (Standardwert: image_classification)"

#: mb/cli.py:317
msgid "Framework to use (default: from config)"
msgstr "Rahmenwerk zum verwenden (Standard: aus der Konfiguration)"

#: mb/cli.py:321
msgid "Model architecture (e.g., resnet34)"
msgstr "Modellarchitektur (z. B. ResNet34)"

#: mb/cli.py:326
msgid "Data directory (default: from config)"
msgstr ""
"Datenverzeichnis (voreausgewählter Wert: Standard: aus der Konfiguration)"

#: mb/cli.py:331
msgid "Output directory for models (default: from config)"
msgstr "Ausgabeverzeichnis für Modelle (Standard: aus der Konfiguration)"

#: mb/cli.py:336
msgid "Number of frozen training epochs (default: from config)"
msgstr ""
"Anzahl der frohenen Trainingsepochen (Standardwert: aus der Konfiguration)"

#: mb/cli.py:341
msgid "Number of unfrozen training epochs (default: from config)"
msgstr ""
"Anzahl von unschlossenen Trainingsepochen (Standardmäßig: vom Config "
"Defaults)"

#: mb/cli.py:346
msgid "Learning rate for frozen phase (default: from config)"
msgstr "Lernrate für die frorene Phase (voredefiniert: aus der Konfiguration)"

#: mb/cli.py:351
msgid "Maximum learning rate for unfrozen phase (default: from config)"
msgstr ""
"Maximaler Lernrate für die nichtgefrorene Phase (Standard: aus der "
"Konfiguration)"

#: mb/cli.py:356
msgid "Minimum learning rate for unfrozen phase (default: from config)"
msgstr ""
"Minimale Lernrate für die nicht gefrorene Phase (Standard: aus der "
"Konfiguration)"

#: mb/cli.py:361
msgid "Batch size (default: from config or auto-detect)"
msgstr ""
"Batchgröße (Standard: aus der Konfiguration oder automatisch ermittelt "
"werden)"

#: mb/cli.py:366
msgid "Image size (default: 224)"
msgstr "Bildgröße (Standard: 224)"

#: mb/cli.py:371
msgid "Number of data loading workers (default: from config)"
msgstr "Anzahl der Datenvorlader (Standard: aus der Konfiguration)"

#: mb/cli.py:376
msgid "Path to checkpoint to resume training from"
msgstr "Pfad zum Checkpunkt um die Training fortzusetzen von"

#: mb/cli.py:386
msgid "Skip updating the unified snapshot with training data"
msgstr ""
"Überspringen Sie die Aktualisierung der einheitlichen Momentaufnahme mit den"
" Trainingdaten."

#: mb/cli.py:393
msgid ""
"Load TrainingRunArgs from JSON (see mb.training.run_args); other train flags"
" are ignored"
msgstr ""
"Laden von TrainingRunArgs aus JSON (siehe mb.training.run_args); andere "
"Train-Flaggen werden ignoriert."

#: mb/cli.py:400
msgid "Convert model between formats"
msgstr "Modell zwischen den Formaten konvertieren"

#: mb/cli.py:402
msgid ""
"Convert a trained model between different formats. Supports PyTorch -> ONNX,"
" PyTorch -> SafeTensors, and Keras -> ONNX."
msgstr ""
"Konvertieren Sie ein trainiertes Modell zwischen verschiedenen Formaten. "
"Unterstützt PyTorch -> ONNX, PyTorch -> SafeTensors und Keras -> ONNX."

#: mb/cli.py:410
msgid "Input model file"
msgstr "Eingabemodell-Datei"

#: mb/cli.py:416
msgid "Output model file"
msgstr "Ausgabedatei des Modells"

#: mb/cli.py:421
msgid "Source framework (auto-detected if not specified)"
msgstr "Quellrahmenwerk (wird automatisch erkannt, sofern nicht angegeben)"

#: mb/cli.py:427
msgid "Target format (onnx or safetensors)"
msgstr "Zielformat (ONNX oder safetensors)"

#: mb/cli.py:431
msgid ""
"Model architecture (required for PyTorch -> ONNX conversion, e.g., "
"'resnet34')"
msgstr ""
"Modellarchitektur (erforderlich für die Konvertierung von PyTorch -> ONNX, "
"z. B., 'resnet34')"

#: mb/cli.py:436
msgid "Number of output classes (required for PyTorch -> ONNX conversion)"
msgstr ""
"Anzahl der Ausgabeklassen (erforderlich für die Konvertierung von PyTorch ->"
" ONNX)"

#: mb/cli.py:442
msgid "Input image size (default: 224, used for ONNX conversion)"
msgstr "Eingabebildgröße (Standard: 224, genutzt für die ONNX-Konvertierung)"

#: mb/cli.py:448
msgid "Show information about models or datasets"
msgstr "Zeigen Sie Informationen zu Modellen oder Datensätzen."

#: mb/cli.py:450
msgid ""
"Display information about trained models or datasets, including metadata, "
"architecture details, and dataset statistics."
msgstr ""
"Zeigen Sie Informationen zu trainierten Modellen oder Datensätzen an, "
"darunter Metadaten, Details zur Architektur und Statistiken zum Datensatz."

#: mb/cli.py:456
msgid "Info subcommands"
msgstr "Info Unterbefehle"

#: mb/cli.py:463
msgid "Show model information"
msgstr "Zeige Modellinformation an"

#: mb/cli.py:465
msgid ""
"Display detailed information about a trained model, including architecture, "
"framework, number of parameters, and training metadata."
msgstr ""
"Zeige detaillierte Informationen zu einem trainierten Modell an, darunter "
"Architektur, Framework, Anzahl der Parameter und Trainingsmetadaten."

#: mb/cli.py:473
msgid "Path to model file"
msgstr "Pfad zur Modelldatei"

#: mb/cli.py:479
msgid "Show dataset information"
msgstr "Datensatzinformation anzeigen"

#: mb/cli.py:481
msgid ""
"Display statistics about a dataset, including class distributions, image "
"counts, and data directory structure."
msgstr ""
"Zeigen Sie Statistiken über einem Dataset an, einschließlich "
"Klassenverteilungen, Bildanzahlen und Datenverzeichnisstruktur."

#: mb/cli.py:489
msgid "Path to data directory"
msgstr "Pfad zum Datenvierzchnis"

#: mb/cli.py:501
msgid "Please specify valid subdirectories using --subdirs argument"
msgstr ""
"Bitte bestimmen Sie gültige Unterordner mithilfe des --subdirs-Arguments."

#: mb/cli.py:510
msgid "Invalid weight format: {pair}. Expected format: subdir:weight"
msgstr "Ungültiger Gewichtsformat: {pair}. Erwarteter Format: subdir:gewicht."

#: mb/cli.py:520
msgid "Weight must be non-negative: {subdir}={weight}"
msgstr "Das Gewicht muss nicht negativ sein: {subdir}={weight}"

#: mb/cli.py:531
msgid "Subdirectories in weights not found in --subdirs: {weights}"
msgstr ""
"Unterverzeichnisse in „weights“, die nicht in --subdirs: {weights} enthalten"
" sind"

#: mb/cli.py:619
msgid "Process terminated due to external storage detection."
msgstr "Prozess wurde beendet aufgrund der externen Speichermedium-Detektion."

#: mb/cli.py:662
msgid "Unsupported framework in JSON: {fw}"
msgstr "Nicht unterstützter Framework in JSON: {fw}"

#: mb/cli.py:666
msgid "Unsupported model type from config: {t}"
msgstr "Nicht unterstützter Modelltyp aus der Konfiguration: {t}"

#: mb/cli.py:671 mb/cli.py:715
msgid "Data directory does not exist: {path}"
msgstr "Datenverzeichnis existiert nicht: {path}"

#: mb/cli.py:683 mb/cli.py:752
msgid "Architecture '{arch}' not supported for framework '{fw}'"
msgstr ""
"Die Architektur '{arch}' wird für das Framework '{fw}' nicht unterstützt."

#: mb/cli.py:692 mb/cli.py:774
msgid "Training completed successfully. Model saved to: {path}"
msgstr ""
"Das Training ist erfolgreich abgeschlossen worden. Modell gespeichert unter:"
" {path}"

#: mb/cli.py:699
msgid "Unsupported framework: {fw}"
msgstr "Nicht unterstützter Framework: {fw}"

#: mb/cli.py:705
msgid "Unsupported model type: {t}"
msgstr "Nicht unterstützter Modelltyp: {t}"

#: mb/cli.py:779
msgid "Training failed: {err}"
msgstr "Training verwarf sich: {err}"

#: mb/cli.py:790
msgid "Input model file not found: {path}"
msgstr "Eingabedatei nicht gefunden: {path}"

#: mb/cli.py:799
msgid "Could not detect source framework. Please specify --framework"
msgstr ""
"Das Source-Rahmenwerk konnte nicht erkannt werden. Bitte angeben Sie "
"--Rahmenwerk"

#: mb/cli.py:805
msgid "PyTorch -> ONNX conversion requires --architecture and --num-classes"
msgstr ""
"PyTorch -> ONNX-Konvertierung erfordert --Architektur und --Anzahl-Klassen"

#: mb/cli.py:824
msgid "Conversion completed successfully: {path}"
msgstr "Konvertierung abgeschlossen erfolgreich: {path}"

#: mb/cli.py:828 ui/pages/convert_page.py:329
msgid "Conversion failed"
msgstr "Konvertierung fehlgeschlagen"

#: mb/cli.py:832
msgid "Conversion error: {err}"
msgstr "Konvertierungfehler: {err}"

#: mb/cli.py:772
msgid "Info model command - not yet implemented"
msgstr "Info-Modell-Befehl - noch nicht implementiert"

#: mb/cli.py:780
msgid "Info dataset command - not yet implemented"
msgstr "Info-Dataset-Command - noch nicht implementiert"

#: mb/cli.py:899
msgid "No data subcommand specified"
msgstr "Kein Datensubcommand angegeben"

#: mb/cli.py:914
msgid "No info subcommand specified"
msgstr "Kein info-Unterbefehl angegeben"

#: mb/cli.py:918 ui/pages/data_page.py:581 ui/pages/data_page.py:685
msgid "Unknown command: {cmd}"
msgstr "Unbekannter Befehl: {cmd}"

#: mb/cli.py:922
msgid "Interrupted by user"
msgstr "Unterbrochen von Benutzer"

#: mb/cli.py:925
msgid "Error: {err}"
msgstr "Fehler: {err}"

